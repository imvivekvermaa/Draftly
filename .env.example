# ---------------------------------------------------------------------------
# Supabase project settings (Project Settings -> API)
# ---------------------------------------------------------------------------
# Public URL of your Supabase project. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# Publishable key (sb_publishable_...), the modern replacement for the legacy
# anon key. Safe to expose to the browser; it is used only by the auth client.
# All data access happens server-side over DATABASE_URL.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ---------------------------------------------------------------------------
# Postgres connection string used ONLY by Drizzle for migrations & queries.
# Project Settings -> Database -> Connection string -> "Session" pooler.
# Never exposed to the browser (no NEXT_PUBLIC_ prefix).
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.your-project-ref:your-db-password@aws-region.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# OpenAI API key used by the content generation endpoint (server-side only).
# https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."
# Optional: override the default model.
OPENAI_MODEL="gpt-4o-mini"
